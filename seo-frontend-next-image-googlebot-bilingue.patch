@@ -1,7 +1,49 @@
 import type { NextConfig } from "next";
 
+type RemoteImageProtocol = "http" | "https";
+
+const buildRemoteImagePattern = (value?: string, pathname = "/uploads/**") => {
+  if (!value) {
+    return null;
+  }
+
+  try {
+    const url = new URL(value);
+
+    if (url.protocol !== "http:" && url.protocol !== "https:") {
+      return null;
+    }
+
+    return {
+      protocol: url.protocol.replace(":", "") as RemoteImageProtocol,
+      hostname: url.hostname,
+      port: url.port,
+      pathname,
+    };
+  } catch {
+    return null;
+  }
+};
+
+type RemoteImagePattern = {
+  protocol: RemoteImageProtocol;
+  hostname: string;
+  port: string;
+  pathname: string;
+};
+
+const remotePatterns = [
+  buildRemoteImagePattern(process.env.NEXT_PUBLIC_API_URL || "http://localhost:4000"),
+  buildRemoteImagePattern(process.env.NEXT_PUBLIC_SITE_URL),
+  buildRemoteImagePattern(process.env.NEXT_PUBLIC_MAIN_SITE_URL, "/**"),
+].filter((pattern): pattern is RemoteImagePattern => Boolean(pattern));
+
 const nextConfig: NextConfig = {
-  /* config options here */
+  images: {
+    formats: ["image/avif", "image/webp"],
+    minimumCacheTTL: 60 * 60 * 24 * 30,
+    remotePatterns,
+  },
 };
 
 export default nextConfig;
