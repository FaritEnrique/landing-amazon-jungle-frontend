+type UserFormState = {
+  fullName: string;
+  dni: string;
+  area: string;
+  email: string;
+  role: AuthRole;
+  password: string;
+  confirmPassword: string;
+};
+
+const emptyForm: UserFormState = {
+  fullName: "",
+  dni: "",
+  area: "Contenido digital",
+  email: "",
+  role: "OPERADOR",
+  password: "",
+  confirmPassword: "",
+};
