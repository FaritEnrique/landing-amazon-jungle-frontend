{
  "name": "landing-amazon-jungle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "doctor:react": "npx --yes react-doctor@latest --no-telemetry",
    "audit:unused": "npx --yes knip@latest",
    "audit:lighthouse": "npm run build && npx --yes @lhci/cli@latest autorun",
    "audit:frontend": "npm run doctor:react && npm run audit:unused",
    "audit:frontend:full": "npm run audit:frontend && npm run audit:lighthouse"
  },
  "dependencies": {
    "lucide-react": "^1.23.0",
    "next": "^16.2.9",
    "postcss": "^8.5.16",
    "react": "^19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.7.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4.3.2",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.16"
  }
}
